# A = 5x9
# B = 9x8
# C = 5x4
#
# 1. t(A %*% B) %*% C = (5*9*8) + (5*8) + (8*5*4) = 560 -> OPTIMAL PLAN
# 2. (t(B) %*% t(A)) %*% C = (9*8) + (5*9) + (8*9*5) + (8*5*4) = 637
# 3. t(B) %*% (t(A) %*% C) = (5*9) + (9*5*8) + (9*8) +(8*9*4) = 765


A = rand(rows=5, cols=9)
B = rand(rows=9, cols=8)
C = rand(rows=5, cols=4)

D = t(A %*% B) %*% C


