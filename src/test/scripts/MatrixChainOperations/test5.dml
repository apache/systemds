# A = 8x3
# B = 3x8
# C = 8x4
#
# 1. t(A %*% B) %*% C = (8*3*8) + (8*8) + (8*8*3) = 512
# 2. (t(B) %*% t(A)) %*% C = (3*8) + (8*3) + (8*3*8) + (8*8*4) = 496
# 3. t(B) %*% (t(A) %*% C) = (8*3) + (3*8*8) + (3*8) +(8*3*4) = 336 -> OPTIMAL PLAN


A = rand(rows=8, cols=3)
B = rand(rows=3, cols=8)
C = rand(rows=8, cols=4)

D = t(A %*% B) %*% C

write(D, $1)
