# A = 8x3
# B = 3x8
# C = 8x4
#
# 1. t(A %*% B) %*% C = (8*3*8) + (8*8) + (8*8*3) = 512
# 2. (t(B) %*% t(A)) %*% C = (3*8) + (8*3) + (8*3*8) + (8*8*4) = 496
# 3. t(B) %*% (t(A) %*% C) = (8*3) + (3*8*8) + (3*8) +(8*3*4) = 336 -> OPTIMAL PLAN


A = rand(rows=1000, cols=10)
B = rand(rows=10, cols=1000)
C = rand(rows=1000, cols=5)

D = t(A %*% B) %*% C

out = sum(D)

print(out)
