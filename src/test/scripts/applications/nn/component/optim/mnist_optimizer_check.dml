source("src/test/scripts/applications/nn/component/optim/adapters/sgd.dml") as optimizer # INSERT ADAPTER-MODULE #

lr = 0.01
mu = 0.9
decay_rate = 0.99
epsilon = 1e-8
beta1 = 0.9
beta2 = 0.999
lambda = 0.01
trust_coeff = 0.001

X = rand(rows=4, cols=3, min=-1, max=1, seed=7)
dX = rand(rows=4, cols=3, min=-0.1, max=0.1, seed=13)

state = optimizer::init_state(X)
[X_upd, state] = optimizer::update_state(X, dX, lr, state, mu, decay_rate,
    epsilon, beta1, beta2, lambda, trust_coeff)
