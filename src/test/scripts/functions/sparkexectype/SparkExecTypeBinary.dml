# Binary operations where exactly one operand is a scalar or a small vector and
# the other operand has a Spark output. These should be pulled into Spark by the
# transitive exec-type decision (matrix-scalar / matrix-vector broadcasting).
X = rand(rows=10000, cols=200, seed=42);
v = rand(rows=1, cols=200, seed=7);   # small row vector (below block size)
c = rand(rows=10000, cols=1, seed=9); # tall column vector

sp1 = X * 2.0;  # matrix-scalar, spark input
sp2 = sp1 + v;  # matrix + small row vector, spark input
sp3 = sp2 - c;  # matrix - column vector, spark input
R = sum(sp3);
write(R, $1, format="text");
